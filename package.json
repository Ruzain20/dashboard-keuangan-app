{
  "name": "dashboard-keuangan",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.jagowebdev.dashboardkeuangan",
    "productName": "Dashboard Keuangan Tenaga Kerja",
    "directories": { "output": "dist" },
    "win": { "target": "portable", "icon": "icon.ico" },
    "portable": { "artifactName": "DashboardKeuangan.exe" }
  }
}